module LFSR(
    input clk,
    input rst,
    output reg [3:0] lfsr_out
);

wire feedback;

assign feedback = lfsr_out[3] ^ lfsr_out[2];

always @(posedge clk or posedge rst) begin

    if(rst)
        lfsr_out <= 4'b0001;

    else
        lfsr_out <= {lfsr_out[2:0], feedback};

end

endmodule




module LFSR_tb;

reg clk;
reg rst;

wire [3:0] lfsr_out;

LFSR uut(
    .clk(clk),
    .rst(rst),
    .lfsr_out(lfsr_out)
);

always #5 clk = ~clk;

initial begin

    clk = 0;
    rst = 1;

    #10 rst = 0;

    #200;

    $stop;

initial begin
$monitor("Time = %0t |LFSR = %b",$time,lfsr-out);

end

endmodule




## Clock
set_property PACKAGE_PIN H17 [get_ports clk]
set_property IOSTANDARD LVCMOS18 [get_ports clk]
create_clock -period 10.000 [get_ports clk]

## Reset
set_property PACKAGE_PIN J18 [get_ports rst]
set_property IOSTANDARD LVCMOS18 [get_ports rst]

## LFSR Outputs
set_property PACKAGE_PIN K19 [get_ports {lfsr_out[0]}]
set_property IOSTANDARD LVCMOS18 [get_ports {lfsr_out[0]}]

set_property PACKAGE_PIN L19 [get_ports {lfsr_out[1]}]
set_property IOSTANDARD LVCMOS18 [get_ports {lfsr_out[1]}]

set_property PACKAGE_PIN M20 [get_ports {lfsr_out[2]}]
set_property IOSTANDARD LVCMOS18 [get_ports {lfsr_out[2]}]

set_property PACKAGE_PIN N20 [get_ports {lfsr_out[3]}]
set_property IOSTANDARD LVCMOS18 [get_ports {lfsr_out[3]}]
